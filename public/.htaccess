AddDefaultCharset UTF-8
Options -Indexes -MultiViews

<IfModule mod_mime.c>
  AddCharset UTF-8 .html .htm .css .js .mjs .json .xml .txt .svg
</IfModule>

# Vraie 404 HTTP servie par Apache pour toute URL inconnue.
# Le build génère déjà /404.html.
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Nettoie les accès explicites à index.html et force directement
  # l'URL canonique en HTTPS + www.
  RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html(?:[\s?]|$) [NC]
  RewriteRule ^(.*/)?index\.html$ https://www.hfconcept.com/$1 [R=301,L,QSA]

  # Redirections 301 des anciennes URLs indexées vers les nouvelles routes.
  # Placées avant la canonicalisation HTTPS + www pour éviter les doubles redirections.
  RewriteRule ^portfolio/?$ https://www.hfconcept.com/realisations/ [R=301,L,NC]
  RewriteRule ^contactez-nous/?$ https://www.hfconcept.com/contact/ [R=301,L,NC]
  RewriteRule ^prestations/?$ https://www.hfconcept.com/services/ [R=301,L,NC]
  RewriteRule ^services/conception-3d-domicile/?$ https://www.hfconcept.com/services/conception-3d/ [R=301,L,NC]

  # Force HTTPS + host canonique.
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} !^www\.hfconcept\.com$ [NC]
  RewriteRule ^ https://www.hfconcept.com%{REQUEST_URI} [R=301,L]

  # Marque les assets Vite hashés pour cache long.
  RewriteRule ^assets/ - [E=IS_HASHED_ASSET:1]

  # Ne jamais réécrire une ressource ou un dossier existant.
  # Les routes publiques pré-rendues existent déjà en dur dans dist/.
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
</IfModule>

<IfModule mod_headers.c>
  # ---- Security headers ----
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "DENY"
  Header always set X-Permitted-Cross-Domain-Policies "none"

  # HSTS : safe si tout le site est servi uniquement en HTTPS
  Header always set Strict-Transport-Security "max-age=31536000"

  # Permissions Policy : on coupe tout ce qui n'est pas utile au site
  Header always set Permissions-Policy "accelerometer=(), ambient-light-sensor=(), autoplay=(), camera=(), display-capture=(), encrypted-media=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), usb=(), xr-spatial-tracking=()"

  # CSP prudente pour ce projet :
  # - autorise self
  # - garde Formspree pour le formulaire
  # - laisse unsafe-inline pour scripts/styles car le site utilise du JSON-LD inline
  #   et quelques styles inline runtime
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://formspree.io; connect-src 'self' https://formspree.io; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; manifest-src 'self'"

  # ---- Cache HTML ----
  <FilesMatch "\.(html?)$">
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>

  # ---- Cache static assets ----
  <FilesMatch "\.(css|js|mjs|json|map|svg|ico|png|jpg|jpeg|gif|webp|avif|woff|woff2|ttf|otf|webmanifest)$">
    Header always set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # Assets Vite hashés : cache long car fingerprintés
  Header always set Cache-Control "public, max-age=31536000, immutable" env=IS_HASHED_ASSET
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On

  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/json "access plus 1 month"

  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/avif "access plus 1 month"

  ExpiresByType font/woff "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 month"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>
