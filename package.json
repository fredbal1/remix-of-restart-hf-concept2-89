{
  "name": "hfconcept",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build && vite build --ssr src/entry-server.tsx --outDir .ssr && tsx scripts/prerender-routes.ts && tsx scripts/validate-dist-seo.ts && tsx scripts/check-bundle-budget.ts",
    "build:dev": "vite build --mode development && vite build --mode development --ssr src/entry-server.tsx --outDir .ssr && tsx scripts/prerender-routes.ts && tsx scripts/validate-dist-seo.ts && tsx scripts/check-bundle-budget.ts",
    "check:bundle-budget": "tsx scripts/check-bundle-budget.ts",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "check": "npm run typecheck && npm run lint && npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.30.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^24.0.0",
    "lovable-tagger": "^1.1.13",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "npm@10",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
